generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  username            String?              @unique
  passwordHash        String?
  role                GlobalRole           @default(MEMBER)
  banned              Boolean              @default(false)
  bannedReason        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastSeenAt          DateTime?
  auditLogs           AuditLog[]
  bansIssued          Ban[]                @relation("BanIssuer")
  bansReceived        Ban[]                @relation("BannedUser")
  channelMemberships  ChannelMember[]
  sentDMs             DirectMessage[]      @relation("DMSender")
  dmThreadsAsUser1    DirectThread[]       @relation("DirectThreadUser1")
  dmThreadsAsUser2    DirectThread[]       @relation("DirectThreadUser2")
  feedComments        FeedComment[]
  feedPosts           FeedPost[]
  feedReactions       FeedReaction[]
  files               File[]
  invitesCreated      Invite[]             @relation("InviteCreator")
  invites             Invite[]
  mentions            Mention[]            @relation("MentionedUser")
  messages            Message[]
  opportunities       Opportunity[]
  opportunityComments OpportunityComment[]
  posts               Post[]
  postAnswers         PostAnswer[]
  reportsFiled        Report[]             @relation("Reporter")
  reportsResolved     Report[]             @relation("ReportResolver")
  spaceMemberships    SpaceMember[]
  tasksAssigned       Task[]               @relation("TaskAssignee")
  tasksCreated        Task[]               @relation("TaskCreator")
  taskComments        TaskComment[]
  threadMemberships   ThreadMember[]

  profile             Profile?
  avatarConfig        AvatarConfig?

  @@index([email])
  @@index([username])
}

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  bio                String?
  pronouns           String?
  location           String?
  supportPreferences String?
  interests          String[]
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvatarConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  avatarId        String?  @default("default")
  head            String   @default("default")
  eyes            String   @default("default")
  brows           String   @default("default")
  mouth           String   @default("default")
  hair            String   @default("default")
  accessories     String[]
  mood            String   @default("neutral")
  background      String   @default("circle")
  backgroundColor String   @default("#ffffff")
  accentColor     String   @default("#000000")
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  createdBy String
  maxUses   Int       @default(1)
  uses      Int       @default(0)
  singleUse Boolean   @default(true)
  expiresAt DateTime?
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  email     String?
  userId    String?
  creator   User      @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([userId])
}

model Space {
  id          String        @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  channels    Channel[]
  files       File[]
  posts       Post[]
  members     SpaceMember[]
  tasks       Task[]
}

model SpaceMember {
  id       String    @id @default(cuid())
  userId   String
  spaceId  String
  role     SpaceRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  space    Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
  @@index([spaceId])
}

model Channel {
  id           String               @id @default(cuid())
  spaceId      String
  name         String
  description  String?
  createdAt    DateTime             @default(now())
  isClosed     Boolean              @default(false)
  space        Space                @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  members      ChannelMember[]
  readReceipts ChannelReadReceipt[]
  messages     Message[]

  @@index([spaceId])
}

model ChannelMember {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model DirectThread {
  id              String          @id @default(cuid())
  user1Id         String?
  user2Id         String?
  createdAt       DateTime        @default(now())
  lastReadUser1At DateTime        @default(now())
  lastReadUser2At DateTime        @default(now())
  avatar          String?
  isGroup         Boolean         @default(false)
  name            String?
  messages        DirectMessage[]
  user1           User?           @relation("DirectThreadUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2           User?           @relation("DirectThreadUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  members         ThreadMember[]

  @@index([user1Id])
  @@index([user2Id])
}

model ThreadMember {
  id       String       @id @default(cuid())
  threadId String
  userId   String
  role     ThreadRole   @default(MEMBER)
  joinedAt DateTime     @default(now())
  thread   DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model DirectMessage {
  id          String       @id @default(cuid())
  threadId    String
  userId      String
  content     String
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  thread      DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User         @relation("DMSender", fields: [userId], references: [id], onDelete: Cascade)
  mentions    Mention[]

  @@index([threadId, createdAt])
}

model ChannelReadReceipt {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

model Message {
  id          String       @id @default(cuid())
  channelId   String
  userId      String
  content     String
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  mentions    Mention[]
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}

model File {
  id         String   @id @default(cuid())
  spaceId    String
  userId     String
  name       String
  size       Int
  mimeType   String
  storageKey String
  url        String
  createdAt  DateTime @default(now())
  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model Task {
  id          String        @id @default(cuid())
  spaceId     String
  title       String
  description String?
  status      TaskStatus    @default(OPEN)
  tags        String[]
  assigneeId  String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  mentions    Mention[]
  assignee    User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User          @relation("TaskCreator", fields: [createdBy], references: [id])
  space       Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  comments    TaskComment[]

  @@index([spaceId, status])
}

model TaskComment {
  id          String       @id @default(cuid())
  taskId      String
  userId      String
  content     String
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  mentions    Mention[]
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String       @id @default(cuid())
  spaceId     String
  userId      String
  title       String
  content     String
  tags        String[]
  solved      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  mentions    Mention[]
  space       Space        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     PostAnswer[]

  @@index([spaceId])
}

model PostAnswer {
  id          String       @id @default(cuid())
  postId      String
  userId      String
  content     String
  accepted    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  attachments Attachment[]
  mentions    Mention[]
  post        Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     ReportStatus @default(PENDING)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())
  reporter   User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver   User?        @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([status])
}

model Ban {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  bannedBy  String
  type      BanType  @default(SOFT)
  createdAt DateTime @default(now())
  issuer    User     @relation("BanIssuer", fields: [bannedBy], references: [id], onDelete: Cascade)
  user      User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([action])
}

model Attachment {
  id                   String              @id @default(cuid())
  name                 String
  size                 Int
  mimeType             String
  url                  String
  storageKey           String
  createdAt            DateTime            @default(now())
  messageId            String?
  directMessageId      String?
  taskCommentId        String?
  postId               String?
  postAnswerId         String?
  opportunityCommentId String?
  opportunityId        String?
  feedCommentId        String?
  feedPostId           String?
  directMessage        DirectMessage?      @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  feedComment          FeedComment?        @relation(fields: [feedCommentId], references: [id], onDelete: Cascade)
  feedPost             FeedPost?           @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  message              Message?            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  opportunityComment   OpportunityComment? @relation(fields: [opportunityCommentId], references: [id], onDelete: Cascade)
  opportunity          Opportunity?        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  postAnswer           PostAnswer?         @relation(fields: [postAnswerId], references: [id], onDelete: Cascade)
  post                 Post?               @relation(fields: [postId], references: [id], onDelete: Cascade)
  taskComment          TaskComment?        @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([directMessageId])
  @@index([taskCommentId])
}

model Mention {
  id                   String              @id @default(cuid())
  userId               String
  messageId            String?
  directMessageId      String?
  taskCommentId        String?
  postId               String?
  postAnswerId         String?
  taskId               String?
  readAt               DateTime?
  createdAt            DateTime            @default(now())
  opportunityCommentId String?
  opportunityId        String?
  feedCommentId        String?
  feedPostId           String?
  directMessage        DirectMessage?      @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  feedComment          FeedComment?        @relation(fields: [feedCommentId], references: [id], onDelete: Cascade)
  feedPost             FeedPost?           @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  message              Message?            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  opportunityComment   OpportunityComment? @relation(fields: [opportunityCommentId], references: [id], onDelete: Cascade)
  opportunity          Opportunity?        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  postAnswer           PostAnswer?         @relation(fields: [postAnswerId], references: [id], onDelete: Cascade)
  post                 Post?               @relation(fields: [postId], references: [id], onDelete: Cascade)
  taskComment          TaskComment?        @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)
  task                 Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user                 User                @relation("MentionedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([messageId])
  @@index([directMessageId])
}

model Opportunity {
  id          String               @id @default(cuid())
  userId      String
  title       String
  content     String
  type        OpportunityType
  location    WorkLocation
  tags        String[]
  link        String?
  contactInfo String?
  deadline    DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  attachments Attachment[]
  mentions    Mention[]
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    OpportunityComment[]

  @@index([type])
  @@index([location])
  @@index([createdAt])
}

model OpportunityComment {
  id            String       @id @default(cuid())
  opportunityId String
  userId        String
  content       String
  createdAt     DateTime     @default(now())
  attachments   Attachment[]
  mentions      Mention[]
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model FeedPost {
  id          String         @id @default(cuid())
  userId      String
  content     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  attachments Attachment[]
  comments    FeedComment[]
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   FeedReaction[]
  mentions    Mention[]

  @@index([userId])
  @@index([createdAt])
}

model FeedComment {
  id          String       @id @default(cuid())
  feedPostId  String
  userId      String
  content     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  post        FeedPost     @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentions    Mention[]

  @@index([feedPostId])
}

model FeedReaction {
  id         String   @id @default(cuid())
  feedPostId String
  userId     String
  type       String
  createdAt  DateTime @default(now())
  post       FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedPostId, userId, type])
}

model JoinRequest {
  id        String            @id @default(cuid())
  name      String
  email     String
  message   String?
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([email])
}

enum GlobalRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum SpaceRole {
  ADMIN
  MODERATOR
  MEMBER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum BanType {
  SOFT
  HARD
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum OpportunityType {
  JOBB
  LIA
  UPPDRAG
}

enum WorkLocation {
  REMOTE
  HYBRID
  ONSITE
}

enum ThreadRole {
  OWNER
  MEMBER
}
